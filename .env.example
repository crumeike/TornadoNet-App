# TornadoNet environment variables
# Copy this file to .env and fill in values — .env is gitignored

# ── Frontend API keys (used at runtime via Settings panel) ────────────────────
VITE_ANTHROPIC_KEY=
VITE_OPENAI_KEY=sk-...
VITE_GEMINI_KEY=AIza...
VITE_GROK_KEY=xai-...

# ── TornadoNet backend URL (used by frontend to connect to FastAPI) ───────────
VITE_TORNADONET_URL=http://localhost:8000

# ── Backend settings ──────────────────────────────────────────────────────────
# HuggingFace token — required only if checkpoints are in a private repo
HF_TOKEN=

# Default confidence threshold for inference (0.01 – 0.99)
TORNADONET_DEFAULT_CONF=0.25
